{
  "name": "kimi-usage-statusbar",
  "displayName": "Kimi Usage Statusbar",
  "description": "在 VSCode 状态栏显示 Kimi Code 实时用量",
  "version": "0.8.0",
  "publisher": "XiaoZ-0218",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/XiaoZ-0218/kimi-usage.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "kimiUsage.showWelcome",
        "title": "打开 Kimi 欢迎页面",
        "icon": "$(sparkle)"
      },
      {
        "command": "kimiUsage.refresh",
        "title": "刷新 Kimi 用量",
        "icon": "$(refresh)"
      },
      {
        "command": "kimiUsage.setToken",
        "title": "设置 Kimi API Key"
      },
      {
        "command": "kimiUsage.openConsole",
        "title": "打开 Kimi Code 控制台"
      },
      {
        "command": "kimiUsage.openSettings",
        "title": "打开 Kimi 用量设置"
      },
      {
        "command": "kimiUsage.toggleMock",
        "title": "切换 Kimi Mock 模式"
      },
      {
        "command": "kimiUsage.openDebugOutput",
        "title": "打开 Kimi 调试输出"
      }
    ],
    "configuration": {
      "title": "Kimi Usage Statusbar",
      "properties": {
        "kimiUsage.displayModeWindow5h": {
          "type": "string",
          "enum": ["remaining", "used"],
          "default": "remaining",
          "description": "5h 滚动窗口显示模式：remaining（剩余百分比）/ used（已使用百分比）"
        },
        "kimiUsage.displayModeWeekly": {
          "type": "string",
          "enum": ["remaining", "used"],
          "default": "remaining",
          "description": "本周额度显示模式：remaining（剩余百分比）/ used（已使用百分比）"
        },
        "kimiUsage.displayModeMonthly": {
          "type": "string",
          "enum": ["remaining", "used"],
          "default": "remaining",
          "description": "赠送额度显示模式：remaining（剩余百分比）/ used（已使用百分比）"
        },
        "kimiUsage.statusBarIcon": {
          "type": "string",
          "default": "sparkle",
          "description": "状态栏图标（VSCode codicon 名称，留空则隐藏图标）"
        },
        "kimiUsage.pollIntervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 120,
          "description": "自动刷新 Kimi 用量的间隔（分钟）"
        },
        "kimiUsage.apiBaseUrl": {
          "type": "string",
          "default": "https://api.kimi.com",
          "description": "Kimi API 基础地址"
        },
        "kimiUsage.mockMode": {
          "type": "boolean",
          "default": false,
          "description": "Mock 模式：不调用真实 API，使用模拟数据"
        },
        "kimiUsage.debugMode": {
          "type": "boolean",
          "default": false,
          "description": "调试模式：在输出面板记录 API 请求与响应"
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "kimiUsage.refresh"
        },
        {
          "command": "kimiUsage.setToken"
        },
        {
          "command": "kimiUsage.openConsole"
        },
        {
          "command": "kimiUsage.openSettings"
        },
        {
          "command": "kimiUsage.toggleMock"
        },
        {
          "command": "kimiUsage.openDebugOutput"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
